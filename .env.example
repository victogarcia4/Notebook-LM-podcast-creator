# Base de datos compartida para Vercel + worker Windows.
# Usa Neon, Supabase Postgres u otro Postgres publico.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Ruta al CLI de NotebookLM (solo en el worker Windows). Usa barras normales (/).
NLM_PATH="C:/Users/<usuario>/.notebooklm-venv/Scripts/notebooklm.exe"

# Python del mismo venv, opcional. Si no se define, se deriva de NLM_PATH.
# NLM_PYTHON="C:/Users/<usuario>/.notebooklm-venv/Scripts/python.exe"

# Carpeta temporal/local donde el worker descarga los MP3 antes de publicarlos.
AUDIO_DIR="public/audio"

# Intervalo de sondeo del worker en milisegundos.
WORKER_POLL_MS=5000

# Storage de audio:
# - local: sirve /public/audio en desarrollo local.
# - s3: sube MP3 a S3 o Cloudflare R2 y guarda una URL publica.
STORAGE_DRIVER="s3"
S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_BUCKET="podcast-audio"
S3_ACCESS_KEY_ID="<access-key-id>"
S3_SECRET_ACCESS_KEY="<secret-access-key>"
S3_PUBLIC_BASE_URL="https://media.tu-dominio.com"
S3_KEY_PREFIX="audio"

# Para algunos proveedores S3 locales/minio. En R2 normalmente queda false.
S3_FORCE_PATH_STYLE="false"

# Opcional: si se define, usa LibreTranslate en vez de Google gtx.
# LIBRETRANSLATE_URL="https://libretranslate.example.com"
