# Base de datos (SQLite local para el MVP)
DATABASE_URL="file:./dev.db"

# Ruta al CLI de NotebookLM (Windows). Usa barras normales (/).
NLM_PATH="C:/Users/<usuario>/.notebooklm-venv/Scripts/notebooklm.exe"

# Carpeta donde se guardan los MP3 generados
AUDIO_DIR="public/audio"

# Intervalo de sondeo del worker en milisegundos
WORKER_POLL_MS=5000
