// Podcast Creator - esquema publico hibrido (Postgres).
// Estados y etapas se guardan como strings para mantener compatibilidad simple.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Podcast {
  id          String   @id @default(cuid())
  title       String
  titleEn     String?  @map("title_en")
  titleEs     String?  @map("title_es")
  topic       String
  format      String   @default("deep-dive")
  length      String   @default("default")
  language    String   @default("es")
  status      String   @default("PENDING")
  notebookId  String?  @map("notebook_id")
  audioPath   String?  @map("audio_path")
  durationSec Int?     @map("duration_sec")
  plays       Int      @default(0)
  errorMsg    String?  @map("error_msg")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sources PodcastSource[]
  job     GenerationJob?

  @@map("podcast_creator_podcasts")
}

model PodcastSource {
  id        String   @id @default(cuid())
  podcastId String   @map("podcast_id")
  kind      String   @default("url")
  value     String
  podcast   Podcast  @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("podcast_creator_sources")
}

model GenerationJob {
  id        String   @id @default(cuid())
  podcastId String   @unique @map("podcast_id")
  status    String   @default("QUEUED")
  stage     String   @default("queued")
  progress  Int      @default(0)
  errorMsg  String?  @map("error_msg")
  attempts  Int      @default(0)
  podcast   Podcast  @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("podcast_creator_generation_jobs")
}

model WorkerStatus {
  id         String   @id @default("default")
  status     String   @default("UNKNOWN")
  authValid  Boolean? @map("auth_valid")
  message    String?
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("podcast_creator_worker_status")
}
